# PDW Client Configuration (RTL-SDR Decoder)
# Copy this to .env and adjust values.
# Run from the client/ directory: docker compose up -d

# ── Server connection ──
PDW_SERVER_URL=http://10.20.50.30:3000
PDW_API_KEY=

# ── RTL-SDR settings ──
PDW_RTL_FREQUENCY=157.950M
PDW_RTL_GAIN=32
PDW_RTL_PPM=0
PDW_RTL_DEVICE=0
PDW_RTL_SAMPLE_RATE=22050
PDW_RTL_SQUELCH=0

# ── Decoders ──
PDW_DECODERS=POCSAG512,POCSAG1200,FLEX

# ── Batching & dedup ──
PDW_BATCH_SIZE=10
PDW_BATCH_INTERVAL_MS=2000
PDW_DEDUP_WINDOW_S=30
PDW_MULTIPART_TIMEOUT_MS=10000

# ── Exclude capcodes (comma-separated, empty = none) ──
PDW_EXCLUDE_CAPCODES=

# ── Debug logging (set to 1 for verbose pipeline logs) ──
PDW_DEBUG=0

# ── Retry & queue limits ──
PDW_MAX_RETRIES=5
PDW_RETRY_BASE_MS=2000
PDW_MAX_QUEUE_SIZE=1000
PDW_PIPELINE_RESTART_DELAY_MS=5000
