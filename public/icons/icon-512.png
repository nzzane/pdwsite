<svg xmlns="http://www.w3.org/2000/svg" width="512" height="512" viewBox="0 0 512 512">
  <defs>
    <linearGradient id="bg" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" style="stop-color:#1e293b"/>
      <stop offset="100%" style="stop-color:#0f172a"/>
    </linearGradient>
    <filter id="glow">
      <feGaussianBlur stdDeviation="3" result="coloredBlur"/>
      <feMerge>
        <feMergeNode in="coloredBlur"/>
        <feMergeNode in="SourceGraphic"/>
      </feMerge>
    </filter>
  </defs>
  <!-- Rounded square background -->
  <rect width="512" height="512" rx="96" ry="96" fill="url(#bg)"/>
  <!-- Subtle inner border -->
  <rect x="8" y="8" width="496" height="496" rx="90" ry="90" fill="none" stroke="#1e293b" stroke-width="2"/>
  <!-- Outer signal arc -->
  <path d="M 340 140 A 140 140 0 0 1 340 330" fill="none" stroke="#3b82f6" stroke-width="14" stroke-linecap="round" opacity="0.4"/>
  <!-- Middle signal arc -->
  <path d="M 312 170 A 100 100 0 0 1 312 300" fill="none" stroke="#3b82f6" stroke-width="14" stroke-linecap="round" opacity="0.65"/>
  <!-- Inner signal arc -->
  <path d="M 284 200 A 60 60 0 0 1 284 270" fill="none" stroke="#3b82f6" stroke-width="14" stroke-linecap="round" opacity="0.9"/>
  <!-- Antenna mast -->
  <line x1="200" y1="120" x2="200" y2="320" stroke="#3b82f6" stroke-width="18" stroke-linecap="round"/>
  <!-- Antenna base bar -->
  <line x1="150" y1="320" x2="250" y2="320" stroke="#3b82f6" stroke-width="18" stroke-linecap="round"/>
  <!-- Signal dot at top of antenna -->
  <circle cx="200" cy="120" r="16" fill="#60a5fa" filter="url(#glow)"/>
  <!-- Antenna base feet -->
  <line x1="160" y1="320" x2="145" y2="355" stroke="#3b82f6" stroke-width="12" stroke-linecap="round"/>
  <line x1="240" y1="320" x2="255" y2="355" stroke="#3b82f6" stroke-width="12" stroke-linecap="round"/>
  <!-- PDW text -->
  <text x="256" y="445" text-anchor="middle" font-family="Arial, Helvetica, sans-serif" font-weight="bold" font-size="80" fill="#e2e8f0" letter-spacing="12">PDW</text>
  <!-- Subtle MONITOR subtext -->
  <text x="256" y="478" text-anchor="middle" font-family="Arial, Helvetica, sans-serif" font-weight="400" font-size="24" fill="#64748b" letter-spacing="8">MONITOR</text>
</svg>
