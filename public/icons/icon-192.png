<svg xmlns="http://www.w3.org/2000/svg" width="192" height="192" viewBox="0 0 192 192">
  <defs>
    <linearGradient id="bg" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" style="stop-color:#1e293b"/>
      <stop offset="100%" style="stop-color:#0f172a"/>
    </linearGradient>
  </defs>
  <!-- Rounded square background -->
  <rect width="192" height="192" rx="38" ry="38" fill="url(#bg)"/>
  <!-- Outer signal arc -->
  <path d="M 126 58 A 50 50 0 0 1 126 122" fill="none" stroke="#3b82f6" stroke-width="6" stroke-linecap="round" opacity="0.5"/>
  <!-- Middle signal arc -->
  <path d="M 116 68 A 35 35 0 0 1 116 112" fill="none" stroke="#3b82f6" stroke-width="6" stroke-linecap="round" opacity="0.75"/>
  <!-- Inner signal arc -->
  <path d="M 106 78 A 20 20 0 0 1 106 102" fill="none" stroke="#3b82f6" stroke-width="6" stroke-linecap="round"/>
  <!-- Antenna mast -->
  <line x1="78" y1="50" x2="78" y2="120" stroke="#3b82f6" stroke-width="7" stroke-linecap="round"/>
  <!-- Antenna base -->
  <line x1="60" y1="120" x2="96" y2="120" stroke="#3b82f6" stroke-width="7" stroke-linecap="round"/>
  <!-- Signal dot at top of antenna -->
  <circle cx="78" cy="50" r="6" fill="#60a5fa"/>
  <!-- Antenna base feet -->
  <line x1="64" y1="120" x2="58" y2="132" stroke="#3b82f6" stroke-width="5" stroke-linecap="round"/>
  <line x1="92" y1="120" x2="98" y2="132" stroke="#3b82f6" stroke-width="5" stroke-linecap="round"/>
  <!-- PDW text -->
  <text x="96" y="168" text-anchor="middle" font-family="Arial, Helvetica, sans-serif" font-weight="bold" font-size="30" fill="#e2e8f0" letter-spacing="4">PDW</text>
</svg>
