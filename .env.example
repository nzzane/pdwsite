# PDW Monitor Configuration
# Copy this to .env and adjust values
# NOTE: A .env file is NOT required for Docker — all secrets are auto-generated on first run.

# Server
PORT=3000
HOST=0.0.0.0

# Auth - auto-generated if not set (persisted to /data/.jwt-secret)
#JWT_SECRET=

# Client API key - auto-generated if not set (persisted to /data/.api-key)
# Can also be managed from the Admin Panel > Settings tab
#API_KEY=

# Admin account (created on first run)
# Default: admin / changeme
#ADMIN_USERNAME=admin
#ADMIN_PASSWORD=changeme

# Web Push (VAPID) - auto-generated if not set
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_EMAIL=mailto:admin@example.com

# Message dedup window (ms)
DEDUP_WINDOW_MS=30000

# Multipart message join timeout (ms)
MULTIPART_TIMEOUT_MS=10000

# ── RTL-SDR FireComm audio streaming ──
# Leave RTL_STREAM_URL empty (or unset) to disable the in-app audio player entirely.
# When running via Docker Compose the rtlsdr service is auto-detected; set this only
# if you run the rtlsdr container separately or on a different host.
#RTL_STREAM_URL=http://rtlsdr:8090

# FireComm stream parameters (tuned via Admin Panel; these are the container defaults)
#RTL_FIRE_FREQ=75.5875M
#RTL_FIRE_MODE=fm
#RTL_FIRE_GAIN=40
#RTL_FIRE_SQUELCH=0

# === Client Script (pdw-client.js) ===

# Server URL the client sends data to
SERVER_URL=http://localhost:3000

# RTL-SDR settings
RTL_FREQUENCY=157.925M
RTL_GAIN=40
RTL_PPM=0
RTL_DEVICE=0
RTL_SAMPLE_RATE=22050

# Decoders (comma-separated)
DECODERS=POCSAG512,POCSAG1200,FLEX

# Set to 1 to read from stdin instead of spawning rtl_fm
READ_STDIN=0
