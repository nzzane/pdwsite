# PDW Monitor Configuration
# Copy this to .env and adjust values

# Server
PORT=3000
HOST=0.0.0.0

# Auth - CHANGE THIS to a random secret
JWT_SECRET=change-me-to-a-random-secret-string

# Client API key - shared between client script and server
API_KEY=change-me-pdw-api-key

# Web Push (VAPID) - generate with: npm run generate-vapid
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_EMAIL=mailto:admin@example.com

# Message dedup window (ms)
DEDUP_WINDOW_MS=30000

# Multipart message join timeout (ms)
MULTIPART_TIMEOUT_MS=10000

# === Client Script (pdw-client.js) ===

# Server URL the client sends data to
SERVER_URL=http://localhost:3000

# RTL-SDR settings
RTL_FREQUENCY=157.925M
RTL_GAIN=40
RTL_PPM=0
RTL_DEVICE=0
RTL_SAMPLE_RATE=22050

# Decoders (comma-separated)
DECODERS=POCSAG512,POCSAG1200,FLEX

# Set to 1 to read from stdin instead of spawning rtl_fm
READ_STDIN=0
