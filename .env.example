# PDW Monitor Configuration
# Copy to .env in the repo root and adjust as needed.
#
# All three containers live on the br0.50 VLAN with static IPs:
#   Server  → 10.20.50.30
#   Client  → 10.20.50.31
#   rtlsdr  → 10.20.50.32
#
# Build from repo root: docker compose -f server/docker-compose.yml up -d --build

# ╔══════════════════════════════════════════════════════════════════╗
# ║  SERVER  (server/docker-compose.yml)                            ║
# ╚══════════════════════════════════════════════════════════════════╝

PDW_PORT=3000

# Auth - auto-generated if not set
#JWT_SECRET=
#API_KEY=

# Admin (first run only)
#ADMIN_USERNAME=admin
#ADMIN_PASSWORD=changeme

# Web Push (VAPID) - auto-generated if not set
#VAPID_PUBLIC_KEY=
#VAPID_PRIVATE_KEY=
VAPID_EMAIL=mailto:admin@example.com

# Tuning
DEDUP_WINDOW_MS=30000
MULTIPART_TIMEOUT_MS=10000

# Message retention (days)
MESSAGE_RETENTION_DAYS=180

# RTL-SDR audio stream — rtlsdr container IP on br0.50
RTL_STREAM_URL=http://10.20.50.32:8090

# Backup configuration
BACKUP_DIR=/data/backups
MAX_BACKUPS=30

# ╔══════════════════════════════════════════════════════════════════╗
# ║  CLIENT  (client/docker-compose.yml)                            ║
# ╚══════════════════════════════════════════════════════════════════╝

# Server IP on br0.50
CLIENT_SERVER_URL=http://10.20.50.30:3000

# RTL-SDR settings (pager frequency)
RTL_FREQUENCY=157.925M
RTL_GAIN=40
RTL_PPM=0
RTL_DEVICE=0
RTL_SAMPLE_RATE=22050
RTL_SQUELCH=0

# Decoders
DECODERS=POCSAG512,POCSAG1200,FLEX

# Batching
BATCH_SIZE=10
BATCH_INTERVAL_MS=2000
DEDUP_WINDOW_S=30

# Capcodes to ignore (comma-separated)
EXCLUDE_CAPCODES=

# Debug (set to 1 for verbose pipeline logs)
DEBUG=0

# FLEX fragment join window (ms) — joins split multimon-ng output lines
FLEX_JOIN_MS=2000

# Silence alert (minutes) — logs warning if no pages received
SILENCE_ALERT_MIN=0

# ╔══════════════════════════════════════════════════════════════════╗
# ║  RTLSDR FIRECOMM  (rtlsdr/docker-compose.yml)                  ║
# ╚══════════════════════════════════════════════════════════════════╝

RTL_FIRE_FREQ=75.5875M
RTL_FIRE_MODE=fm
RTL_FIRE_GAIN=40
RTL_FIRE_SQUELCH=0
