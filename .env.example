# PDW Monitor Configuration
# Copy this to .env and adjust values as needed.
# NOTE: A .env file is NOT required — all secrets are auto-generated on first run.
#
# Architecture:
#   docker-compose.yml           — Server (always required)
#   docker-compose.client.yml    — Pager decoder client (needs RTL-SDR dongle)
#   docker-compose.rtlsdr.yml   — FireComm audio streaming (needs RTL-SDR dongle)

# ╔══════════════════════════════════════════════════════════════════╗
# ║  SERVER  (docker-compose.yml)                                   ║
# ╚══════════════════════════════════════════════════════════════════╝

# Exposed port on the host
PDW_PORT=3000

# Auth - auto-generated if not set (persisted to /data/.jwt-secret)
#JWT_SECRET=

# Client API key - auto-generated if not set (persisted to /data/.api-key)
# Shared between server and client; also configurable via Admin Panel > Settings
#API_KEY=

# Admin account (created on first run only)
#ADMIN_USERNAME=admin
#ADMIN_PASSWORD=changeme

# Web Push (VAPID) - auto-generated if not set
#VAPID_PUBLIC_KEY=
#VAPID_PRIVATE_KEY=
VAPID_EMAIL=mailto:admin@example.com

# Tuning
DEDUP_WINDOW_MS=30000
MULTIPART_TIMEOUT_MS=10000

# RTL-SDR audio stream URL — set this when running docker-compose.rtlsdr.yml
# The rtlsdr container is reachable as "rtlsdr" on the shared pdw-net network.
# Leave empty/unset to disable the in-app audio player entirely.
#RTL_STREAM_URL=http://rtlsdr:8090

# ╔══════════════════════════════════════════════════════════════════╗
# ║  CLIENT  (docker-compose.client.yml)                            ║
# ╚══════════════════════════════════════════════════════════════════╝

# Server URL — when on the same Docker host, use the container name
CLIENT_SERVER_URL=http://pdw-monitor:3000

# RTL-SDR settings (pager frequency)
RTL_FREQUENCY=157.925M
RTL_GAIN=40
RTL_PPM=0
RTL_DEVICE=0
RTL_SAMPLE_RATE=22050
RTL_SQUELCH=0

# Decoders (comma-separated)
DECODERS=POCSAG512,POCSAG1200,FLEX

# Batching
BATCH_SIZE=10
BATCH_INTERVAL_MS=2000
DEDUP_WINDOW_S=30

# Capcodes to ignore (comma-separated, e.g. test pagers)
EXCLUDE_CAPCODES=1234567

# ╔══════════════════════════════════════════════════════════════════╗
# ║  RTLSDR FIRECOMM  (docker-compose.rtlsdr.yml)                  ║
# ╚══════════════════════════════════════════════════════════════════╝

# FireComm stream parameters (also tuneable via Admin Panel > Audio Settings)
RTL_FIRE_FREQ=75.5875M
RTL_FIRE_MODE=fm
RTL_FIRE_GAIN=40
RTL_FIRE_SQUELCH=0
